DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=irida_detailing
DB_USER=irida_user
DB_PASSWORD=change_me_database_password

SECRET_KEY=change_this_to_a_long_random_secret_key_min_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Local frontend origins
CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500

# Optional admin auto-create on first start
ADMIN_FULL_NAME=Администратор Irida Center
ADMIN_EMAIL=admin@irida-center.ru
ADMIN_PHONE=+7 (900) 000-00-00
ADMIN_PASSWORD=change_admin_password_123

# Yandex OAuth
YANDEX_OAUTH_CLIENT_ID=your-yandex-client-id
YANDEX_OAUTH_CLIENT_SECRET=your-yandex-client-secret
YANDEX_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/users/oauth/yandex/callback
