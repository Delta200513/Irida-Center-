DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=irida_detailing
DB_USER=irida_user
DB_PASSWORD=change_me_strong_database_password

SECRET_KEY=change_me_to_a_long_random_secret_key_min_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Replace with your real frontend domain(s)
CORS_ORIGINS=https://your-domain.ru,https://www.your-domain.ru

# Optional admin auto-create on first start
ADMIN_FULL_NAME=Администратор Irida Center
ADMIN_EMAIL=admin@your-domain.ru
ADMIN_PHONE=+7 (900) 000-00-00
ADMIN_PASSWORD=change_me_strong_admin_password

# Yandex OAuth for production
YANDEX_OAUTH_CLIENT_ID=your-yandex-client-id
YANDEX_OAUTH_CLIENT_SECRET=your-yandex-client-secret
YANDEX_OAUTH_REDIRECT_URI=https://your-domain.ru/api/users/oauth/yandex/callback
